generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Lead {
  id           String   @id @default(uuid())
  bitrixLeadId String?  @unique
  name         String
  email        String
  phone        String?
  source       String?  // Form source (e.g. "Main Form", "Horizon View")
  isJunk       Boolean  @default(false)
  junkReason   String?  // e.g. "Suspicious email format", "asdf pattern"
  payload      String?  // JSON string containing full form data
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relations
  deals        Deal[]
}

model Deal {
  id           String   @id @default(uuid())
  bitrixDealId String   @unique
  title        String
  stageId      String   // e.g., "NEW", "PREPARATION", "LOSE", "1"
  assignedTo   String?  // e.g., "Ventas", "Pedro Torres"
  stageDate    DateTime? // the last time the stage was changed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // A deal can be created from a Lead
  leadId       String?
  lead         Lead?    @relation(fields: [leadId], references: [id])
}
